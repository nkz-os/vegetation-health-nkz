#!/bin/sh
MSG=$(cat "$1")

CLEAN=$(printf "%s\n" "$MSG" | sed \
  -e '/^[Cc][Oo]-[Aa]uthored-[Bb]y:/d' \
  -e '/^[Mm]ade-[Ww]ith:/d' \
  -e '/^[Mm]ade [Ww]ith [Cc]ursor/d' \
  -e '/^[Mm]ade [Bb]y [Cc]ursor/d' \
  -e '/^[Mm]ade-with: [Cc]ursor/d' \
  -e '/cursoragent@cursor\.com/d' \
  -e '/^[Cc]ursor-Agent:/d')

if [ "$CLEAN" != "$MSG" ]; then
  printf "%s" "$CLEAN" > "$1"
  MSG="$CLEAN"
  echo "commit-msg: stripped agent attribution line(s)" >&2
fi

LEN=$(printf "%s" "$MSG" | wc -c)
LINES=$(printf "%s" "$MSG" | wc -l)

if echo "$MSG" | grep -qE "[áéíóúñçÁÉÍÓÚÑÇ]"; then
  echo ""
  echo "ERROR: non-English characters in commit message."
  echo "All commits must be in English (public repo)."
  echo ""
  exit 1
fi

if [ "$LINES" -gt 4 ] || [ "$LEN" -gt 300 ]; then
  echo ""
  echo "ERROR: commit message too long ($LINES lines, $LEN chars)."
  echo "Keep it short. Max 4 lines / 300 chars."
  echo ""
  exit 1
fi
