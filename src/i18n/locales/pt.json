        "ndvi": {
            "fullName": "Normalized Difference Vegetation Index",
            "description": "The most widely used index for measuring vegetation greenness and health. Compares reflected light in visible red and near-infrared.",
            "interpretation": {
                "veryLow": "Water, snow, clouds, or bare soil",
                "low": "Sparse or stressed vegetation",
                "medium": "Moderate vegetation, grasslands, or shrubs",
                "high": "Dense, healthy vegetation",
                "veryHigh": "Dense tropical forest or high-biomass crops"
            },
            "bestFor": [
                "General crop monitoring",
                "Water stress detection",
                "Land cover classification",
                "Seasonal change detection"
            ],
            "limitations": [
                "Saturates in dense vegetation (LAI > 3)",
                "Affected by soil brightness in arid areas",
                "Does not distinguish well between crop types"
            ]
        },
        "evi": {
            "fullName": "Enhanced Vegetation Index",
            "description": "Optimized to reduce atmospheric and soil influence, using the blue band for correction.",
            "interpretation": {
                "veryLow": "Water or urban infrastructure",
                "low": "Very sparse vegetation or bare soils",
                "medium": "Early-stage crops or pastures",
                "high": "Dense, active vegetation cover",
                "veryHigh": "Dense forests and high-yield plantations"
            },
            "bestFor": [
                "High-biomass areas (rainforests, plantations)",
                "Regions with atmospheric influence (humidity, aerosols)",
                "Monitoring in high soil reflectance areas"
            ],
            "limitations": [
                "Requires precise atmospheric correction",
                "More computationally complex",
                "Less sensitive in areas with low vegetation cover"
            ]
        },
        "ndmi": {
            "fullName": "Normalized Difference Moisture Index",
            "description": "Detects changes in vegetation water content using infrared bands.",
            "interpretation": {
                "veryLow": "Severe drought or dead vegetation",
                "low": "Moderate water stress",
                "medium": "Normal moisture conditions",
                "high": "Good vegetation hydration",
                "veryHigh": "Water saturation, possible flooding"
            },
            "bestFor": [
                "Crop water stress detection",
                "Drought monitoring",
                "Fire risk assessment",
                "Irrigation management"
            ],
            "limitations": [
                "Lower spatial resolution (20m, SWIR band)",
                "Affected by dense clouds and shadows",
                "Does not discriminate between soil and vegetation water"
            ]
        },
        "savi": {
            "fullName": "Soil-Adjusted Vegetation Index",
            "description": "NDVI variant that minimizes soil brightness influence, ideal for young crops.",
            "interpretation": {
                "veryLow": "Bare soil or stubble",
                "low": "Germinating crops (< 15% cover)",
                "medium": "Early vegetative development (15-50% cover)",
                "high": "Medium-high vegetation cover (50-80%)",
                "veryHigh": "Full, dense cover (> 80%)"
            },
            "bestFor": [
                "Early-stage crops",
                "Arid and semi-arid areas",
                "Where soil is visible between plants",
                "Vineyards and olive groves with wide spacing"
            ],
            "limitations": [
                "Requires adjusting L factor by cover",
                "Less sensitive than NDVI in dense covers",
                "L=0.5 value is a compromise"
            ]
        },
        "gndvi": {
            "fullName": "Green Normalized Difference Vegetation Index",
            "description": "Uses the green band instead of red, offering higher sensitivity to chlorophyll.",
            "interpretation": {
                "veryLow": "Bare soil or water",
                "low": "Chlorotic vegetation (nitrogen deficiency)",
                "medium": "Crops with normal chlorophyll levels",
                "high": "High chlorophyll concentration, good health",
                "veryHigh": "Maximum photosynthetic activity"
            },
            "bestFor": [
                "Chlorophyll content assessment",
                "Nitrogen deficiency detection",
                "Crop senescence monitoring",
                "Plant species differentiation"
            ],
            "limitations": [
                "Smaller dynamic range than NDVI",
                "More sensitive to lighting conditions",
                "Green band (B03) has lower signal-to-noise ratio"
            ]
        },
        "ndre": {
            "fullName": "Normalized Difference Red Edge",
            "description": "Uses the Red Edge band, highly sensitive to subtle changes in vegetation health.",
            "interpretation": {
                "veryLow": "Dead or severely stressed vegetation",
                "low": "Nutritional stress or early chlorosis",
                "medium": "Crops with adequate nutrition",
                "high": "High photosynthetic efficiency",
                "veryHigh": "Optimal health and chlorophyll density"
            },
            "bestFor": [
                "Precision agriculture (variable N rate)",
                "Early crop stress detection",
                "Crop variety classification",
                "Foliar senescence monitoring"
            ],
            "limitations": [
                "Requires Red Edge band (B05, B06, B7, or B8A)",
                "Lower availability on non-Sentinel-2 satellites",
                "Can be affected by canopy structure"
            ]
        }
    }
